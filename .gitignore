# IIIF.Manifest.Serializer.Net
# .NET library repo ignore rules

# ---------------------------------------------------------------------------
# User-specific IDE and editor state
# ---------------------------------------------------------------------------
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.DotSettings.user

# ---------------------------------------------------------------------------
# Local AI and analysis tooling
# ---------------------------------------------------------------------------
.agents/
.claude/
.codex/
.code-review-graph/

# ---------------------------------------------------------------------------
# Build outputs
# ---------------------------------------------------------------------------
**/[Bb]in/
**/[Oo]bj/
**/[Dd]ebug/
**/[Dd]ebugPublic/
**/[Rr]elease/
**/[Rr]eleases/
**/[Pp]ublish/
**/[Aa]pp[Pp]ackages/
artifacts/

# ---------------------------------------------------------------------------
# Test results and coverage
# ---------------------------------------------------------------------------
TestResults/
**/TestResults/
[Tt]est[Rr]esult*/
*.trx
*.coverage
*.coveragexml
*.dotCover
coverage/
coverage-raw/
coverage-report/

# ---------------------------------------------------------------------------
# NuGet and package artifacts
# ---------------------------------------------------------------------------
*.nupkg
*.snupkg
*.symbols.nupkg
*.nuspec
packages/
.nuget/
nuget.exe

# Keep checked-in package fixtures if tests add them later.
!**/TestData/*.nupkg
!**/TestData/*.snupkg

# ---------------------------------------------------------------------------
# Publish profiles and local deployment settings
# ---------------------------------------------------------------------------
*.[Pp]ublish.xml
*.pubxml
*.azurePubxml
*.publishsettings

# ---------------------------------------------------------------------------
# Logs, diagnostics, and temporary files
# ---------------------------------------------------------------------------
*.log
*.tmp
*.tmp_proj
*.cache
*.cachefile
*.binlog
*.pidb
*.svclog
*.orig
*~
~$*

# ---------------------------------------------------------------------------
# Generated compiler and native build intermediates
# ---------------------------------------------------------------------------
*.dll
*.exe
*.pdb
*.mdb
*.ilk
*.obj
*.iobj
*.ipdb
*.pch
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
ipch/

# ---------------------------------------------------------------------------
# Legacy .NET/Visual Studio generated files
# ---------------------------------------------------------------------------
AssemblyInfo.g.cs
DebugConstants.cs
ClientBin/
Generated_Code/
FakesAssemblies/

# ---------------------------------------------------------------------------
# ReSharper, Rider, NCrunch, and other .NET tooling
# ---------------------------------------------------------------------------
_ReSharper*/
*.[Rr]e[Ss]harper
_TeamCity*
_NCrunch_*
.*crunch*.local.xml
*.ncrunchsolution
*.ncrunchproject
.JustCode
AutoTest.Net/

# ---------------------------------------------------------------------------
# Node and frontend tooling, if introduced by docs or examples
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# OS metadata
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
